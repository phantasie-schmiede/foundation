{
    "authors": [
        {
            "email": "dn@phantasie-schmiede.de",
            "name": "Daniel Ablass",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "PSBits\\Foundation\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PSBits\\Foundation\\Tests\\": "Tests",
            "TYPO3\\CMS\\Core\\Tests\\": ".Build/vendor/typo3/cms-core/Tests"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "bin-dir": ".Build/bin",
        "preferred-install": {
            "typo3/cms-core": "source",
            "*": "dist"
        },
        "sort-packages": true,
        "vendor-dir": ".Build/vendor"
    },
    "description": "Configuration framework for TYPO3 extension development",
    "extra": {
        "typo3/cms": {
            "extension-key": "foundation",
            "web-dir": ".Build/public"
        }
    },
    "keywords": [
        "configuration",
        "development",
        "extension",
        "typo3"
    ],
    "license": "GPL-3.0-or-later",
    "name": "psbits/foundation",
    "require": {
        "ext-fileinfo": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-simplexml": "*",
        "php": "^8.3",
        "typo3/cms-core": "^12.4 || ^13.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "helmich/typo3-typoscript-lint": "^3.3",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11",
        "roave/security-advisories": "dev-latest",
        "saschaegerer/phpstan-typo3": "^2.1",
        "typo3/coding-standards": "^0.5.3",
        "typo3/testing-framework": "^8.2"
    },
    "scripts": {
        "analyze:php": "phpstan analyse --configuration=Build/Quality/phpstan.neon.dist --no-progress",
        "audit:composer": "composer audit --abandoned=report",
        "fix:classes": "npm run fix:classes",
        "fix:htmlxml": "npm run fix:htmlxml",
        "fix:php": "php-cs-fixer fix --config=Build/Quality/.php-cs-fixer.dist.php --verbose",
        "lint:classes": "npm run lint:classes",
        "lint:htmlxml": "npm run lint:htmlxml",
        "lint:php": "php-cs-fixer fix --config=Build/Quality/.php-cs-fixer.dist.php --dry-run --diff --verbose",
        "lint:typoscript": "typoscript-lint --config=Build/Quality/typoscript-lint.yml --ansi Configuration/TypoScript",
        "lint:yaml": "bash -lc 'command -v yamllint >/dev/null 2>&1 || sudo apt install -y yamllint; yamllint -c Build/Quality/.yamllint.yml Build/Quality Configuration'",
        "post-install-cmd": [
            "npm install",
            "cp Build/GitHooks/pre-commit .git/hooks/pre-commit"
        ],
        "qa": [
            "@analyze:php",
            "@audit:composer",
            "@lint:classes",
            "@lint:htmlxml",
            "@lint:php",
            "@lint:typoscript",
            "@lint:yaml",
            "@validate:composer"
        ],
        "validate:composer": "composer validate --no-check-publish"
    },
    "type": "typo3-cms-extension"
}
